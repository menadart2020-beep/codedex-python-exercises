import random
emoji = {
         "rock" : "🪨",
         "paper" : "📄",
         "scissor" : "✂️"}
choice = ["rock", "paper", "scissor"]
win_game = []
lose_game = []

lives = 5
while lives > 0:
   computer_choice = random.choice(choice)
   guess = input("enter (rock, paper or scissor) : ").lower()
   if guess not in choice:
       print("invalid choice")  
       continue
   print(f"you{emoji[guess]}")         
   print(f"computer choice {emoji[computer_choice]}")        
   if guess == computer_choice:
      print("draw")
   elif guess== "rock" and computer_choice == "scissor":
      print("win")
      win_game.append(guess)  
         
   elif guess == "scissor" and computer_choice == "paper":
      print("win")
      win_game.append(guess)       
          
   elif guess == "paper" and computer_choice == "rock":
      print("win")
      win_game.append(guess)  
   else :
      print("lose")
      lives -= 1
      print(f"you left {lives}") 
      lose_game.append(guess)       

print("game over")
print("lives left",lives)        
print("you win",win_game) 
print("you lose",lose_game)
